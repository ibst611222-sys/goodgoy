# === Financial Modeling Prep ===
# Get a free API key at: https://financialmodelingprep.com/developer
# (Optional — app falls back to mock data without it)
NEXT_PUBLIC_FMP_API_KEY=your_fmp_api_key_here

# For server-side API proxy (more secure — use this instead of NEXT_PUBLIC_FMP_API_KEY)
FMP_API_KEY=your_fmp_api_key_here

# === Supabase (Auth + Database) ===
# Create a free project at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
